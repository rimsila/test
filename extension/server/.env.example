PORT=4783
REPO_PATH=C:\\path\\to\\your\\git-project
PROJECT_PATH=C:\\path\\to\\your\\git-project
EXTENSION_TOKEN=replace-with-a-long-random-token

# For MCP clients that support a static Bearer token.
MCP_TOKEN=replace-with-a-different-long-random-token

# ChatGPT developer-mode apps commonly use OAuth or no auth. Only set this to
# true temporarily behind a private tunnel URL when testing. Never expose an
# unauthenticated endpoint permanently.
ALLOW_UNAUTHENTICATED_MCP=false

AUTO_SYNC_INTERVAL_MINUTES=5
PREVIEW_PORT=5173

# Leave blank to use the built-in static preview server for PROJECT_PATH.
# For Vite/Next/etc, set your own command and matching URL.
PREVIEW_COMMAND=
PREVIEW_URL=http://127.0.0.1:5173

MAX_FILE_BYTES=1048576
MAX_READ_BYTES=262144
MAX_TOOL_OUTPUT_CHARS=200000
ALLOWED_ORIGINS=
